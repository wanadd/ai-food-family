# PLANAM local prod-parity audit environment.
# Copy to .env.local-parity and adjust LOCAL_PARITY_TELEGRAM_ID after importing a snapshot.

COMPOSE_PROJECT_NAME=planam-local-parity

PLANAM_ENV=local-parity
ENVIRONMENT=development
LOCAL_PARITY_MODE=true
LOCAL_PARITY_TELEGRAM_ID=589328345

DISABLE_EXTERNAL_SIDE_EFFECTS=true
TELEGRAM_OUTBOUND_ENABLED=false
CARE_SCHEDULER_ENABLED=false
NOTIFICATION_SCHEDULER_ENABLED=false
TELEGRAM_AUTO_SETUP_WEBHOOK=false

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_LOCAL_PARITY_MODE=true
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
NEXT_PUBLIC_TELEGRAM_APP_SHORT_NAME=
NEXT_PUBLIC_PLANAM_UI_2026=true

BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_WEBAPP_URL=http://localhost:3000
TELEGRAM_WEBHOOK_URL=
TELEGRAM_MENU_BUTTON_TEXT=Открыть ПланАм

POSTGRES_USER=aifood
POSTGRES_PASSWORD=aifood
POSTGRES_DB=aifood
DATABASE_URL=postgresql://aifood:aifood@postgres:5432/aifood
REDIS_URL=redis://redis:6379/0

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ADMIN_TELEGRAM_IDS=
ADMIN_PIN=
ADMIN_PANEL_ENABLED=true
BACKUP_ROOT=backups
