# Production deploy (Timeweb Cloud VPS)
# Copy to .env on the server: cp .env.production.example .env

COMPOSE_PROJECT_NAME=ai-food-family

# Public domain (A-record must point to server IP)
DOMAIN=food.example.com
CERTBOT_EMAIL=admin@example.com

# HTTPS URLs (single domain; API is proxied at /api)
NEXT_PUBLIC_API_URL=https://food.example.com/api
TELEGRAM_WEBAPP_URL=https://food.example.com
BACKEND_CORS_ORIGINS=https://food.example.com

# Telegram
TELEGRAM_BOT_TOKEN=
# Auto-registered on API start → https://food.example.com/api/telegram/webhook
TELEGRAM_WEBHOOK_URL=
TELEGRAM_AUTO_SETUP_WEBHOOK=true
TELEGRAM_MENU_BUTTON_TEXT=Открыть ПланАм
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
NEXT_PUBLIC_TELEGRAM_APP_SHORT_NAME=

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Admin panel (owner Telegram IDs, comma-separated)
ADMIN_TELEGRAM_IDS=
BACKUP_ROOT=backups

# PostgreSQL — use strong passwords in production
POSTGRES_USER=aifood
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=aifood

# Internal URLs (defaults work inside Docker network)
DATABASE_URL=postgresql://aifood:change_me_strong_password@postgres:5432/aifood
REDIS_URL=redis://redis:6379/0

# nginx template: app-init.conf.template (HTTP) or app-ssl.conf.template (HTTPS)
NGINX_TEMPLATE=app-init.conf.template
