# Shared local settings
COMPOSE_PROJECT_NAME=ai-food-family

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
NEXT_PUBLIC_TELEGRAM_APP_SHORT_NAME=

# Backend
BACKEND_CORS_ORIGINS=http://localhost:3000
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_URL=http://localhost:3000
# Webhook URL (auto: TELEGRAM_WEBAPP_URL + /api/telegram/webhook). For local dev use ngrok:
# TELEGRAM_WEBHOOK_URL=https://xxxx.ngrok-free.app/api/telegram/webhook
TELEGRAM_WEBHOOK_URL=
TELEGRAM_AUTO_SETUP_WEBHOOK=true
TELEGRAM_MENU_BUTTON_TEXT=Открыть ПланАм
DATABASE_URL=postgresql://aifood:aifood@postgres:5432/aifood
REDIS_URL=redis://redis:6379/0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Admin panel (hidden; access via Telegram bot /admin + PIN)
ADMIN_TELEGRAM_IDS=
ADMIN_PIN=
ADMIN_PANEL_ENABLED=true
BACKUP_ROOT=backups

# development = local dev auth; production = Telegram only
ENVIRONMENT=development

# PostgreSQL
POSTGRES_USER=aifood
POSTGRES_PASSWORD=aifood
POSTGRES_DB=aifood
