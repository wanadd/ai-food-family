# Local dev: http://localhost:8000
# Production (Telegram Mini App): https://planam.ru/api
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
NEXT_PUBLIC_TELEGRAM_APP_SHORT_NAME=

# PLANAM 2026 — false = legacy UI; true = AppShell2026 + routes. Preview DS: /dev/planam-2026
NEXT_PUBLIC_PLANAM_UI_2026=false
# Grace redirects legacy→2026 (requires UI_2026=true). Off by default (Sprint 2).
NEXT_PUBLIC_PLANAM_ROUTE_REDIRECTS=false
NEXT_PUBLIC_PLANAM_DEFER_PHONE_GATE=true
